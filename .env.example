# Buyer wallet private key
PRIVATE_KEY=

# Observer wallet private key
OBSERVER_PRIVATE_KEY=

# RPC
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
SEPOLIA_RPC_URL=https://ethereum-sepolia.publicnode.com

# Reloadly Sandbox API (observer needs these)
# Sign up at reloadly.com → toggle Test mode → Developers → API Settings
# Sandbox gives $1000 test balance with fake gift card codes
RELOADLY_CLIENT_ID=
RELOADLY_CLIENT_SECRET=

# Pinata IPFS (for storing AES-encrypted gift card codes)
# Sign up at pinata.cloud → API Keys → New Key
PINATA_JWT=
PINATA_GATEWAY=gateway.pinata.cloud
