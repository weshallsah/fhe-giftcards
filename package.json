{
  "name": "sigill",
  "version": "0.1.0",
  "private": true,
  "description": "Sigill — private FHE-backed checkout on Base Sepolia",
  "scripts": {
    "app:dev": "pnpm --filter @sigill/app dev",
    "app:build": "pnpm --filter @sigill/app build",
    "app:start": "pnpm --filter @sigill/app start",
    "landing:dev": "pnpm --filter @sigill/landing dev",
    "landing:build": "pnpm --filter @sigill/landing build",
    "landing:start": "pnpm --filter @sigill/landing start",
    "contracts:compile": "pnpm --filter @sigill/contracts compile",
    "contracts:test": "pnpm --filter @sigill/contracts test",
    "contracts:deploy": "pnpm --filter @sigill/contracts deploy",
    "contracts:observer": "pnpm --filter @sigill/contracts observer"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.3"
}
